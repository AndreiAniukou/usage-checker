# Build outputs
build/
DerivedData/

# Generated Xcode project (we use xcodegen)
*.xcodeproj/
!UsageTracker.xcodeproj/project.pbxproj.example
# Generated by xcodegen from project.yml's info: block
UsageTracker/Info.plist

# Xcode user data
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.xccheckout

# Swift Package Manager
.build/
Packages/
Package.resolved
.swiftpm/

# Signing — personal Team ID & identity (must NEVER be committed)
signing.xcconfig
local.xcconfig
# Generated at build time from signing.xcconfig; contains the Team ID
scripts/exportOptions.plist
.env
.env.local
*.local.yml

# Claude Code local settings (paths reveal username)
.claude/
.cursor/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Pre-built artifacts
*.dmg
*.app
*.xcarchive
*.pkg

# Notarization staging
notarization/
*.zip

# Asset generation scripts output
/tmp/

# Editor
.vscode/
.idea/
*.swp
*.swo
